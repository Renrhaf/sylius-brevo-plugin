{# Brevo Conversations (Live Chat) Widget — inject in shop base footer #}
{% if brevo_chat_enabled and brevo_chat_widget_id %}
<script>
    (function(d, w, c) {
        w.BrevoConversationsID = '{{ brevo_chat_widget_id|e('js') }}';
        w[c] = w[c] || function() {
            (w[c].q = w[c].q || []).push(arguments);
        };
        var s = d.createElement('script');
        s.async = true;
        s.src = 'https://conversations-widget.brevo.com/brevo-conversations.js';
        if (d.head) d.head.appendChild(s);
    })(document, window, 'BrevoConversations');
</script>
{% endif %}
