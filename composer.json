{
    "name": "renrhaf/sylius-brevo-plugin",
    "description": "Sylius plugin for Brevo (formerly Sendinblue) — full e-commerce integration, newsletter, contact sync, email tracking, abandoned cart, and admin dashboard.",
    "type": "sylius-plugin",
    "license": "MIT",
    "keywords": [
        "sylius",
        "brevo",
        "sendinblue",
        "ecommerce",
        "newsletter",
        "email",
        "marketing",
        "abandoned-cart",
        "contact-sync"
    ],
    "require": {
        "php": "^8.2",
        "sylius/sylius": "^2.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/http-client": "^7.0",
        "symfony/event-dispatcher": "^7.0",
        "symfony/console": "^7.0",
        "doctrine/orm": "^3.0",
        "doctrine/dbal": "^4.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "symplify/easy-coding-standard": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Renrhaf\\SyliusBrevoPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Renrhaf\\SyliusBrevoPlugin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "symfony": {
            "require": "^7.0"
        }
    },
    "config": {
        "sort-packages": true
    }
}
